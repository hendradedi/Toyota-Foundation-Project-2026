# Digital RT-Muban Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
APP_NAME=Digital RT-Muban
APP_VERSION=1.0.0
APP_PORT=3000
APP_HOST=0.0.0.0

# ============================================
# Database Configuration
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=rt_muban_db
DB_USER=rt_muban_user
DB_PASSWORD=secure_password_change_me
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# MongoDB Configuration (for logs and analytics)
# ============================================
MONGODB_URI=mongodb://mongo:27017/rt_muban_logs
MONGODB_USER=rt_muban_user
MONGODB_PASSWORD=secure_password_change_me

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# Authentication
# ============================================
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=1800000

# ============================================
# Email Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@rt-muban.example.com

# ============================================
# SMS Configuration (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Firebase Configuration (Push Notifications)
# ============================================
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ============================================
# AWS S3 Configuration
# ============================================
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=rt-muban-files
AWS_S3_URL=https://rt-muban-files.s3.amazonaws.com

# ============================================
# Payment Gateway Configuration
# ============================================
# Midtrans (Indonesia)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_ENVIRONMENT=sandbox

# Omise (Thailand)
OMISE_SECRET_KEY=your_omise_secret_key
OMISE_PUBLIC_KEY=your_omise_public_key

# ============================================
# Google Maps API
# ============================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_DIR=./logs

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003
CORS_CREDENTIALS=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Frontend URLs
# ============================================
WEB_APP_URL=http://localhost:3001
ADMIN_DASHBOARD_URL=http://localhost:3002
MOBILE_APP_URL=rt-muban://

# ============================================
# API Documentation
# ============================================
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# ============================================
# Feature Flags
# ============================================
FEATURE_WASTE_BANKING=true
FEATURE_MARKETPLACE=true
FEATURE_SOS=true
FEATURE_PATROL=true
FEATURE_ADMINISTRATION=true

# ============================================
# Localization
# ============================================
DEFAULT_LANGUAGE=id
SUPPORTED_LANGUAGES=id,th,en
DEFAULT_TIMEZONE=Asia/Jakarta

# ============================================
# Security
# ============================================
ENABLE_HTTPS=false
ENABLE_HELMET=true
ENABLE_CORS=true
ENABLE_RATE_LIMITING=true
ENABLE_REQUEST_LOGGING=true

# ============================================
# Monitoring & Analytics
# ============================================
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
DATADOG_API_KEY=

# ============================================
# Development Tools
# ============================================
DEBUG=rt-muban:*
MOCK_EXTERNAL_SERVICES=false
