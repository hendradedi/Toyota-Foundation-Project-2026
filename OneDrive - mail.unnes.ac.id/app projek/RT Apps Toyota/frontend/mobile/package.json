    "@react-native-async-storage/async-storage": "^1.17.0",
    "axios": "^1.4.0",
    "socket.io-client": "^4.6.1",
    "zustand": "^4.3.8",
    "react-native-vector-icons": "^9.2.0",
    "react-native-maps": "^1.3.2",
